<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Gallery — OHS Art Club</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Cormorant Garamond', 'serif'],
          sans: ['DM Sans', 'sans-serif'],
        },
        colors: {
          navy: '#0e1b35', 'navy-mid': '#162244',
          parchment: '#f7f2eb', 'parchment-dark': '#ede5d8',
          'warm-white': '#faf8f5',
          gold: '#b8873a', 'gold-light': '#d4a85c', 'gold-pale': '#f0ddb8',
          ink: '#1a1612', 'ink-mid': '#3d3530', 'ink-soft': '#7a6f66', 'ink-faint': '#b5aca3',
        },
      }
    }
  }
</script>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --navy: #0e1b35; --navy-mid: #162244;
  --parchment: #f7f2eb; --parchment-dark: #ede5d8; --warm-white: #faf8f5;
  --gold: #b8873a; --gold-light: #d4a85c; --gold-pale: #f0ddb8;
  --ink: #1a1612; --ink-mid: #3d3530; --ink-soft: #7a6f66; --ink-faint: #b5aca3;
  --border: rgba(26,22,18,0.1); --border-strong: rgba(26,22,18,0.18);
}
html { scroll-behavior: smooth; }
body { background: var(--warm-white); color: var(--ink); font-family: 'DM Sans', sans-serif; font-weight: 300; overflow-x: hidden; }

/* NAV */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1.2rem 4rem; background: rgba(250,248,245,0.93); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
.nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--navy); text-decoration: none; font-weight: 400; }
.nav-links { display: flex; gap: 2.5rem; list-style: none; }
.nav-links a { font-size: 0.75rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-soft); text-decoration: none; transition: color 0.25s; }
.nav-links a:hover { color: var(--ink); }
.nav-links a.active { color: var(--navy); border-bottom: 1px solid var(--gold); padding-bottom: 2px; }
@media (max-width: 640px) { nav { padding: 1rem 1.5rem; } .nav-links { display: none; } }

/* SECTIONS */
section { padding: 6rem 4rem; }
@media (max-width: 768px) { section { padding: 4rem 1.5rem; } }
@media (max-width: 480px) { section { padding: 3rem 1.25rem; } }
.section-label { font-size: 0.65rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem; }
.section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,5vw,3.6rem); font-weight: 300; line-height: 1.06; color: var(--navy); margin-bottom: 1.2rem; }
.section-title em { font-style: italic; color: var(--ink-mid); }
.divider-line { width: 44px; height: 1px; background: var(--gold); margin-bottom: 2rem; }
.btn { font-family: 'DM Sans', sans-serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; padding: 0.85rem 2rem; text-decoration: none; transition: all 0.25s; cursor: pointer; border: none; display: inline-block; }
.btn-primary { background: var(--navy); color: var(--parchment); }
.btn-primary:hover { background: var(--navy-mid); }
.btn-outline { border: 1px solid var(--border-strong); color: var(--ink); background: transparent; }
.btn-outline:hover { border-color: var(--ink); background: rgba(26,22,18,0.04); }
.btn-gold { background: var(--gold); color: #fff; }
.btn-gold:hover { background: var(--gold-light); }

/* PAGE HERO */
.page-hero { min-height: 100vh; position: relative; display: flex; align-items: center; background: var(--parchment); overflow: hidden; padding-top: 80px; }
.hero-bg-grid { position: absolute; inset: 0; display: grid; grid-template-columns: repeat(7,1fr); grid-template-rows: repeat(5,1fr); }
.hbg-cell { overflow: hidden; }
.hbg-cell svg { width: 100%; height: 100%; display: block; }
.hero-bg-overlay { position: absolute; inset: 0; background: rgba(247,242,235,0.72); }
.page-hero-content { position: relative; z-index: 2; padding: 3.5rem 4rem 4.5rem; max-width: 860px; }
@media (max-width: 640px) { .page-hero-content { padding: 2rem 1.5rem 3rem; } }
.page-hero-eyebrow { font-size: 0.65rem; letter-spacing: 0.38em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem; animation: fadeUp 0.85s ease both; }
.page-hero-eyebrow::before { content:''; display:inline-block; width:28px; height:1px; background:var(--gold); }
.page-hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(3.5rem,11vw,8rem); font-weight: 300; line-height: 0.88; letter-spacing: -0.01em; color: var(--navy); margin-bottom: 1.4rem; animation: fadeUp 0.85s 0.1s ease both; }
.page-hero-title em { font-style: italic; color: var(--ink-mid); }
.page-hero-sub { font-size: 0.88rem; line-height: 1.85; color: var(--ink-soft); max-width: 46ch; margin-bottom: 2rem; animation: fadeUp 0.85s 0.22s ease both; }
.page-hero-meta { display: flex; align-items: center; gap: 1.8rem; flex-wrap: wrap; animation: fadeUp 0.85s 0.32s ease both; }
.meta-pill { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft); display: flex; align-items: center; gap: 0.5rem; }
.meta-pill::before { content:''; display:inline-block; width:4px; height:4px; border-radius:50%; background:var(--gold); flex-shrink:0; }
.torn-bottom { position: absolute; left: -2px; right: -2px; bottom: -1px; z-index: 3; pointer-events: none; }

/* STATS STRIP */
.stats-strip { display: grid; grid-template-columns: repeat(4,1fr); border-bottom: 1px solid var(--border-strong); }
.stat-cell { padding: 2rem 2.5rem; border-right: 1px solid var(--border); background: #fff; display: flex; flex-direction: column; gap: 0.2rem; }
.stat-cell:last-child { border-right: none; }
.stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; font-weight: 300; color: var(--gold); line-height: 1; }
.stat-lbl { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-top: 0.15rem; }
@media (max-width: 768px) { .stats-strip { grid-template-columns: repeat(2,1fr); } .stat-cell { padding: 1.4rem 1.5rem; } .stat-cell:nth-child(2) { border-right: none; } }

/* FILTER BAR */
.filter-bar { background: rgba(250,248,245,0.95); padding: 1.6rem 4rem; border-bottom: 1px solid var(--border); position: sticky; top: 64px; z-index: 50; backdrop-filter: blur(10px); display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
@media (max-width: 640px) { .filter-bar { padding: 1rem 1.5rem; top: 60px; } }
.filter-lbl { font-size: 0.62rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-right: 0.4rem; white-space: nowrap; }
.filter-btn { font-family: 'DM Sans', sans-serif; font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; padding: 0.42rem 1.1rem; border: 1px solid var(--border-strong); background: none; color: var(--ink-soft); cursor: pointer; transition: all 0.22s; }
.filter-btn:hover { border-color: var(--ink); color: var(--ink); }
.filter-btn.active { background: var(--navy); border-color: var(--navy); color: var(--parchment); }

/* FEATURED BANNER */
.featured-wrap { max-width: 1200px; margin: 0 auto; }
.featured-banner { border: 1px solid var(--border-strong); background: #fff; display: grid; grid-template-columns: 1fr 1.55fr; overflow: hidden; }
.feat-art { min-height: 360px; overflow: hidden; background: var(--parchment); }
.feat-art svg { width: 100%; height: 100%; min-height: 360px; display: block; }
.feat-info { padding: 3rem 3.5rem; display: flex; flex-direction: column; justify-content: center; border-left: 1px solid var(--border); }
.feat-tag { display: inline-flex; align-items: center; gap: 0.6rem; font-size: 0.62rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; }
.feat-tag::before { content:''; display:block; width:18px; height:1px; background:var(--gold); }
.feat-name { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: var(--navy); margin-bottom: 0.3rem; line-height: 1.1; }
.feat-meta { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 1.2rem; }
.feat-desc { font-size: 0.88rem; line-height: 1.85; color: var(--ink-soft); margin-bottom: 1.8rem; max-width: 38ch; }
.feat-chips { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2rem; }
.chip { font-size: 0.66rem; letter-spacing: 0.1em; padding: 0.25rem 0.7rem; border: 1px solid var(--border-strong); color: var(--ink-mid); font-family: 'DM Sans', sans-serif; }
@media (max-width: 900px) {
  .featured-banner { grid-template-columns: 1fr; }
  .feat-art { min-height: 240px; } .feat-art svg { min-height: 240px; }
  .feat-info { padding: 2rem 1.5rem; border-left: none; border-top: 1px solid var(--border); }
}

/* MASONRY */
.gallery-section { background: var(--parchment); }
.gallery-inner { max-width: 1200px; margin: 0 auto; }
.gallery-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
.masonry { columns: 3 260px; column-gap: 3px; }
.m-item { break-inside: avoid; margin-bottom: 3px; position: relative; overflow: hidden; cursor: pointer; background: var(--parchment-dark); }
.m-item img { display: block; width: 100%; transition: transform 0.55s cubic-bezier(0.4,0,0.2,1); }
.m-item:hover img { transform: scale(1.045); }
.m-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(14,27,53,0.88) 0%, transparent 52%); opacity: 0; transition: opacity 0.3s; display: flex; flex-direction: column; justify-content: flex-end; padding: 1.4rem; }
.m-item:hover .m-overlay { opacity: 1; }
.m-year { position: absolute; top: 0.85rem; right: 0.85rem; font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; background: var(--gold); color: #fff; padding: 0.18rem 0.55rem; font-family: 'DM Sans', sans-serif; }
.m-title { font-family: 'Cormorant Garamond', serif; font-size: 1.12rem; color: var(--parchment); margin-bottom: 0.15rem; }
.m-sub { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-pale); }
@media (hover: none) { .m-overlay { opacity: 1; } }

/* ARCHIVE LIST */
.archive-section { background: var(--warm-white); }
.archive-inner { max-width: 1200px; margin: 0 auto; }
.archive-list { display: flex; flex-direction: column; gap: 1px; border: 1px solid var(--border-strong); overflow: hidden; background: var(--border); }
.archive-row { display: grid; grid-template-columns: 110px 1fr auto; align-items: center; gap: 2rem; padding: 1.6rem 2rem; background: #fff; transition: background 0.22s; }
.archive-row:hover { background: var(--parchment); }
.ar-year { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: var(--gold); }
.ar-name { font-family: 'Cormorant Garamond', serif; font-size: 1.22rem; font-weight: 400; color: var(--navy); margin-bottom: 0.18rem; }
.ar-theme { font-size: 0.72rem; font-style: italic; color: var(--ink-soft); margin-bottom: 0.22rem; }
.ar-count { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-faint); }
.ar-tag { font-family: 'DM Sans', sans-serif; font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; padding: 0.3rem 0.9rem; border: 1px solid var(--border-strong); color: var(--ink-soft); white-space: nowrap; transition: all 0.22s; cursor: pointer; }
.archive-row:hover .ar-tag { border-color: var(--gold); color: var(--gold); }
@media (max-width: 640px) { .archive-row { grid-template-columns: 76px 1fr; gap: 1rem; padding: 1.2rem 1rem; } .ar-tag { display: none; } .ar-year { font-size: 1.45rem; } }

/* LIGHTBOX */
.lightbox { position: fixed; inset: 0; z-index: 1000; background: rgba(14,27,53,0.94); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.35s ease; backdrop-filter: blur(8px); }
.lightbox.open { opacity: 1; pointer-events: all; }
.lb-inner { position: relative; max-width: min(88vw, 1050px); max-height: 90vh; display: flex; flex-direction: column; align-items: center; transform: scale(0.95) translateY(14px); transition: transform 0.38s cubic-bezier(0.4,0,0.2,1); }
.lightbox.open .lb-inner { transform: scale(1) translateY(0); }
.lb-img { max-width: 100%; max-height: 72vh; object-fit: contain; display: block; }
.lb-info { margin-top: 1.5rem; width: 100%; padding-top: 1.2rem; border-top: 1px solid rgba(184,135,58,0.25); display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
.lb-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: var(--parchment); margin-bottom: 0.2rem; }
.lb-sub { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(240,221,184,0.52); }
.lb-counter { font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; color: rgba(240,221,184,0.38); align-self: flex-end; white-space: nowrap; }
.lb-close { position: fixed; top: 1.4rem; right: 1.4rem; width: 42px; height: 42px; border: 1px solid rgba(184,135,58,0.35); background: rgba(14,27,53,0.65); color: var(--parchment); font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.22s; backdrop-filter: blur(4px); }
.lb-close:hover { background: var(--gold); border-color: var(--gold); }
.lb-nav { position: fixed; top: 50%; transform: translateY(-50%); width: 46px; height: 46px; border: 1px solid rgba(184,135,58,0.25); background: rgba(14,27,53,0.55); color: var(--parchment); font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.22s; backdrop-filter: blur(4px); }
.lb-nav:hover { background: var(--gold); border-color: var(--gold); }
.lb-prev { left: 1.2rem; }
.lb-next { right: 1.2rem; }

/* FOOTER */
footer { border-top: 1px solid var(--border); padding: 2rem 4rem; display: flex; align-items: center; justify-content: space-between; background: var(--warm-white); flex-wrap: wrap; gap: 0.75rem; }
.footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 0.95rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--ink); }
.footer-copy { font-size: 0.7rem; letter-spacing: 0.08em; color: var(--ink-faint); }
@media (max-width: 640px) { footer { padding: 1.5rem; flex-direction: column; align-items: flex-start; } }

/* DARK MODE — identical to original */
body.dark {
  --navy: #c8d8f0; --navy-mid: #a8bedd;
  --parchment: #0d1525; --parchment-dark: #111c30; --warm-white: #0a1020;
  --ink: #dce8f8; --ink-mid: #a8bedd; --ink-soft: #6880a8; --ink-faint: #374d6e;
  --border: rgba(180,210,255,0.08); --border-strong: rgba(180,210,255,0.14);
}
body.dark { background: var(--warm-white); color: var(--ink); }
body.dark nav { background: rgba(10,16,32,0.95); }
body.dark .stat-cell, body.dark .featured-banner, body.dark .feat-info,
body.dark .archive-row { background: #111c30; }
body.dark .archive-row:hover { background: #0d1525; }
body.dark .filter-bar { background: rgba(10,16,32,0.96); }
body.dark .page-hero { background: var(--parchment); }
body.dark .hero-bg-overlay { background: rgba(10,16,32,0.78); }
body.dark .torn-bottom path { fill: var(--warm-white); }
body.dark footer { background: var(--warm-white); }
body.dark .gallery-section { background: var(--parchment); }
body.dark .archive-section { background: var(--warm-white); }

.dark-toggle { background: none; border: 1px solid var(--border-strong); color: var(--ink-soft); cursor: pointer; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; transition: border-color 0.25s, color 0.25s; flex-shrink: 0; }
.dark-toggle:hover { border-color: var(--gold); color: var(--gold); }
.dark-toggle svg { width: 15px; height: 15px; }
.dark-toggle .icon-moon { display: block; }
.dark-toggle .icon-sun  { display: none; }
body.dark .dark-toggle .icon-moon { display: none; }
body.dark .dark-toggle .icon-sun  { display: block; }

/* ANIMATIONS */
@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
.reveal { opacity:0; transform:translateY(26px); transition: opacity 0.75s ease, transform 0.75s ease; }
.reveal.visible { opacity:1; transform:none; }
.reveal-delay-1 { transition-delay:0.12s; }
.reveal-delay-2 { transition-delay:0.24s; }
.reveal-delay-3 { transition-delay:0.36s; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">OHS Art Club</a>
  <ul class="nav-links">
    <li><a href="#featured">Spotlight</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="#archive">Archives</a></li>
  </ul>
