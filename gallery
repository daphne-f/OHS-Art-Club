</div>

<!-- FILTER BAR -->
<div id="gallery" style="position:relative; top:-64px; visibility:hidden; pointer-events:none;"></div>
<div class="filter-bar">
    <span class="filter-lbl">Filter by</span>
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="painting">Painting</button>
    <button class="filter-btn" data-filter="digital">Digital</button>
    <button class="filter-btn" data-filter="photography">Photography</button>
    <button class="filter-btn" data-filter="mixed">Mixed Media</button>
    <button class="filter-btn" data-filter="sculpture">Sculpture</button>
  </div>
<div>

<!-- MASONRY GALLERY -->
<section class="gallery-section"
  <div class="gallery-inner">
    <div class="gallery-header">
      <div>
        <p class="section-label reveal">Browse the Work</p>
        <h2 class="section-title reveal reveal-delay-1">From the <em>Collection</em></h2>
      </div>
      <span class="reveal" id="countLabel" style="font-size:0.68rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-soft);align-self:flex-end;"></span>
    </div>
    <div class="masonry" id="masonryGrid"></div>
  </div>
</section>



<!-- ARCHIVE BY YEAR -->
<section class="archive-section" id="archive">
  <div class="archive-inner">
    <div style="margin-bottom:2.5rem;">
      <h2 class="section-title reveal reveal-delay-1">Showcase <em>Archive</em></h2>
      <div class="divider-line reveal reveal-delay-2"></div>
    </div>
    <div class="archive-list reveal">
      <div class="archive-row"><div class="ar-year">year</div><div><div class="ar-name">Showcase Title</div><div class="ar-count">## Artists · ## Submissions</div></div><div class="ar-tag">View Gallery</div></div>
      <div class="archive-row"><div class="ar-year">year</div><div><div class="ar-name">Showcase Title</div><div class="ar-count">## Artists · ## Submissions</div></div><div class="ar-tag">View Gallery</div></div>
      <div class="archive-row"><div class="ar-year">year</div><div><div class="ar-name">Showcase Title</div><div class="ar-count">## Artists · ## Submissions</div></div><div class="ar-tag">View Gallery</div></div>
      <div class="archive-row"><div class="ar-year">year</div><div><div class="ar-name">Showcase Title</div><div class="ar-count">## Artists · ## Submissions</div></div><div class="ar-tag">View Gallery</div></div>
      <div class="archive-row"><div class="ar-year">year</div><div><div class="ar-name">Showcase Title</div><div class="ar-count">## Artists · ## Submissions</div></div><div class="ar-tag">View Gallery</div></div>
      <div class="archive-row"><div class="ar-year">year</div><div><div class="ar-name">Showcase Title</div><div class="ar-count">## Artists · ## Submissions</div></div><div class="ar-tag">View Gallery</div></div>
    </div>
  </div>
</section>

<footer>
  <span class="footer-logo">OHS Art Club</span>
  <span class="footer-copy">© 2026 Stanford Online High School Art Club. All rights reserved.</span>
</footer>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true">
  <button class="lb-close" id="lbClose">✕</button>
  <button class="lb-nav lb-prev" id="lbPrev">‹</button>
  <button class="lb-nav lb-next" id="lbNext">›</button>
  <div class="lb-inner">
    <img class="lb-img" id="lbImg" src="" alt="" />
    <div class="lb-info">
      <div><div class="lb-title" id="lbTitle"></div><div class="lb-sub" id="lbSub"></div></div>
      <div class="lb-counter" id="lbCounter"></div>
    </div>
  </div>
</div>

<script>
/* ── Artwork data ── */
const artworks = [
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:800,  h:1050, title:"Title",   artist:"Artist",    medium:"Oil on Canvas",    year:"year", cat:"painting"    },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:900,  h:620,  title:"Title",   artist:"Artist",    medium:"Digital Painting", year:"year", cat:"digital"     },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:720,  h:960,  title:"Title",   artist:"Artist",    medium:"Watercolor",       year:"year", cat:"painting"    },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:1000, h:700,  title:"Title",   artist:"Artist",    medium:"Photography",      year:"year", cat:"photography" },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:800,  h:820,  title:"Title",   artist:"Artist",    medium:"Mixed Media",      year:"year", cat:"mixed"       },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:620,  h:900,  title:"Title",   artist:"Artist",    medium:"Sculpture",        year:"year", cat:"sculpture"   },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:900,  h:700,  title:"Title",   artist:"Artist",    medium:"Digital Art",      year:"year", cat:"digital"     },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:760,  h:1060, title:"Title",   artist:"Artist",    medium:"Acrylic",          year:"year", cat:"painting"    },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:860,  h:640,  title:"Title",   artist:"Artist",    medium:"Photography",      year:"year", cat:"photography" },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:800,  h:960,  title:"Title",   artist:"Artist",    medium:"Collage",          year:"year", cat:"mixed"       },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:900,  h:900,  title:"Title",   artist:"Artist",    medium:"Digital Painting", year:"year", cat:"digital"     },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:700,  h:1000, title:"Title",   artist:"Artist",    medium:"Oil on Canvas",    year:"year", cat:"painting"    },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:1000, h:740,  title:"Title",   artist:"Artist",    medium:"Mixed Media",      year:"year", cat:"mixed"       },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:800,  h:1100, title:"Title",   artist:"Artist",    medium:"Watercolor",       year:"year", cat:"painting"    },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:920,  h:680,  title:"Title",   artist:"Artist",    medium:"Photography",      year:"year", cat:"photography" },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:740,  h:960,  title:"Title",   artist:"Artist",    medium:"Sculpture",        year:"year", cat:"sculpture"   },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:1000, h:700,  title:"Title",   artist:"Artist",    medium:"Digital Art",      year:"year", cat:"digital"     },
  { img:"https://i.ibb.co/bjWZd8LL/place.jpg",  w:800,  h:1060, title:"Title",   artist:"Artist",    medium:"Mixed Media",      year:"year", cat:"mixed"       },
];

/* ── Hero background collage (same generation as original) ── */
(function() {
  const grid = document.getElementById('heroBgGrid');
  const images = [
    "https://i.ibb.co/bjWZd8LL/place.jpg",
  ];
  for (let i = 0; i < 35; i++) {
    const cell = document.createElement('div');
    cell.className = 'hbg-cell';
    cell.innerHTML = `<img src="${images[i % images.length]}" style="width:100%;height:100%;object-fit:cover;display:block;" />`;
    grid.appendChild(cell);
  }
})();

/* ── Masonry grid builder ── */
let visibleArt = [...artworks];

function buildGrid(filter) {
  const grid = document.getElementById('masonryGrid');
  grid.innerHTML = '';
  visibleArt = filter === 'all' ? [...artworks] : artworks.filter(a => a.cat === filter);
  document.getElementById('countLabel').textContent = visibleArt.length + ' works';
  visibleArt.forEach((art, idx) => {
    const el = document.createElement('div');
    el.className = 'm-item';
    el.innerHTML = `
      <img src="${art.img}" loading="lazy" />
      <div class="m-overlay">
        <span class="m-year">${art.year}</span>
        <div class="m-title">${art.title}</div>
        <div class="m-sub">${art.artist} · ${art.medium}</div>
      </div>`;
    el.addEventListener('click', () => openLightbox(idx));
    grid.appendChild(el);
  });
}
buildGrid('all');

/* ── Filter buttons ── */
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    buildGrid(btn.dataset.filter);
  });
});

/* ── Lightbox ── */
const lb = document.getElementById('lightbox');
let cur = 0;
function openLightbox(idx) { cur = idx; updateLb(); lb.classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeLightbox() { lb.classList.remove('open'); document.body.style.overflow = ''; }
function updateLb() {
  const a = visibleArt[cur];
  document.getElementById('lbImg').src = a.img;
  document.getElementById('lbImg').alt = a.title;
  document.getElementById('lbTitle').textContent = a.title;
  document.getElementById('lbSub').textContent = `${a.artist} · ${a.medium} · ${a.year}`;
}
document.getElementById('lbClose').addEventListener('click', closeLightbox);
document.getElementById('lbPrev').addEventListener('click', () => { cur = (cur - 1 + visibleArt.length) % visibleArt.length; updateLb(); });
document.getElementById('lbNext').addEventListener('click', () => { cur = (cur + 1) % visibleArt.length; updateLb(); });
lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
document.addEventListener('keydown', e => {
  if (!lb.classList.contains('open')) return;
  if (e.key === 'Escape') closeLightbox();
  if (e.key === 'ArrowLeft')  { cur = (cur - 1 + visibleArt.length) % visibleArt.length; updateLb(); }
  if (e.key === 'ArrowRight') { cur = (cur + 1) % visibleArt.length; updateLb(); }
});

/* ── Scroll reveals ── */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

/* ── Dark mode — identical logic to original ── */
const DARK_START = 18, DARK_END = 6, LS_KEY = 'ohsArtClub_darkMode';
function isNightTime() { const h = new Date().getHours(); return h >= DARK_START || h < DARK_END; }
function applyDark(on) { document.body.classList.toggle('dark', on); }
function getPreference() { return localStorage.getItem(LS_KEY) || 'auto'; }
function setPreference(v) { localStorage.setItem(LS_KEY, v); }
function resolveMode() { const p = getPreference(); if (p==='dark') return true; if (p==='light') return false; return isNightTime(); }
applyDark(resolveMode());
document.getElementById('darkToggle').addEventListener('click', () => {
  const pref = getPreference();
  const dark = document.body.classList.contains('dark');
  setPreference(pref === 'auto' ? (dark ? 'light' : 'dark') : 'auto');
  applyDark(resolveMode());
});
setInterval(() => { if (getPreference() === 'auto') applyDark(resolveMode()); }, 60000);
</script>
</body>
</html>
