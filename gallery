  <div class="stat-cell"><div class="stat-num">##</div><div class="stat-lbl">Years</div></div>
</div>

<!-- FEATURED EXHIBITION -->
<section style="background:var(--warm-white);" id="featured">
    <div class="featured-wrap">
    <div style="margin-bottom:2.5rem;">
      <p class="section-label reveal">Featured Showcase</p>
      <h2 class="section-title reveal reveal-delay-1">[Showcase Name]</h2>
      <div class="divider-line reveal reveal-delay-2"></div>
    </div>
    <div class="featured-banner reveal">
      <div class="feat-art">
         <img src="https://i.ibb.co/bjWZd8LL/place.jpg" alt="Showcase image" style="width:100%; height:100%; object-fit:cover;" />
        </div>
      <div class="feat-info">
        <p class="feat-name">[Showcase]</p>
        <p class="feat-meta">Date/Year &nbsp;·&nbsp; # Artists &nbsp;·&nbsp; ## Submissions</p>
